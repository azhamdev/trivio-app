# Copy to .env and fill in. Get a key at https://openrouter.ai/keys
# NOTE: EXPO_PUBLIC_* vars are inlined into the client bundle — fine for a
# demo/free-tier key, but production should proxy LLM calls through a backend.
EXPO_PUBLIC_OPENROUTER_API_KEY=

# Supabase project (Project Settings → API). The anon key is safe to ship in
# the bundle — Row Level Security is what protects the data.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
